# Database — replace with your actual Supabase connection string
DATABASE_URL=postgresql://postgres:[password]@db.YOUR_PROJECT.supabase.co:5432/postgres

# App Settings
APP_ENV=development
APP_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
DEBUG=false

# CORS (comma-separated frontend URLs)
FRONTEND_URL=http://localhost:5173

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
